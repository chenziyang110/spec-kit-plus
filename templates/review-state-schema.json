{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": ".specify/templates/review-state-schema.json",
  "title": "Spec Kit Plus System Review State",
  "type": "object",
  "required": [
    "version",
    "schema_ref",
    "status",
    "source",
    "entrypoints",
    "scenarios",
    "obligations",
    "human_acceptance_obligations",
    "human_acceptance_scenarios",
    "implementation_deferrals",
    "reviewed_runtime_targets",
    "review_assignments",
    "fix_assignments",
    "revalidations",
    "coverage",
    "leader",
    "rounds",
    "findings",
    "repair_cycles",
    "validation",
    "cursor",
    "final"
  ],
  "properties": {
    "version": { "const": 2 },
    "schema_ref": { "const": ".specify/templates/review-state-schema.json" },
    "status": {
      "enum": ["gathering", "reviewing", "repairing", "validating", "approved", "blocked", "stale"]
    },
    "source": {
      "type": "object",
      "required": ["workflow_revision", "implementation_fingerprint", "implementation_handoff_sha256", "review_cycle", "review_cycle_id", "previous_review_state_sha256", "acceptance_finding_id", "acceptance_finding_sha256"],
      "properties": {
        "workflow_revision": { "type": "integer", "minimum": 0 },
        "implementation_fingerprint": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "implementation_handoff_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "review_cycle": { "type": "integer", "minimum": 1 },
        "review_cycle_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "previous_review_state_sha256": { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" },
        "acceptance_finding_id": { "type": "string" },
        "acceptance_finding_sha256": { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" },
        "restart_reason": { "enum": ["stale-review-restart"] }
      },
      "additionalProperties": false
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "command", "ready_signal"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "ready_signal": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "title", "required", "entrypoint_id", "actions", "expected_results", "required_evidence", "obligation_ids", "result", "evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["startup", "wiring", "interaction", "ui", "integration", "regression"] },
          "title": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "entrypoint_id": { "type": "string", "minLength": 1 },
          "preconditions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "actions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "expected_results": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["structure_snapshot", "visual_capture", "runtime_diagnostics", "invocation", "side_effect"] }
          },
          "obligation_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "result": { "enum": ["pending", "pass", "fail", "blocked", "not_run"] },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind", "path", "evidence_scope", "snapshot_sha256", "review_cycle_id", "artifact_sha256"],
              "properties": {
                "kind": { "enum": ["structure_snapshot", "visual_capture", "runtime_diagnostics", "invocation", "side_effect"] },
                "path": { "type": "string", "minLength": 1 },
                "evidence_scope": { "const": "integrated" },
                "snapshot_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
                "review_cycle_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
                "artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "obligations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "source_ref", "surface", "required", "scenario_ids", "review_assignment_ids", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "source_ref": { "type": "string", "minLength": 1 },
          "surface": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "scenario_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "review_assignment_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "status": { "enum": ["pending", "covered", "blocked"] }
        },
        "additionalProperties": true
      }
    },
    "human_acceptance_obligations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "source_ref", "change_kind", "user_outcome", "required", "scenario_ids"],
        "properties": {
          "id": { "type": "string", "pattern": "^HAO-.+" },
          "source_ref": { "type": "string", "minLength": 1 },
          "change_kind": { "enum": ["new", "changed"] },
          "user_outcome": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "scenario_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^HA-.+" }
          }
        },
        "additionalProperties": false
      }
    },
    "human_acceptance_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "user_value", "actor", "required", "obligation_ids", "entrypoint_id", "review_scenario_ids", "start_state", "steps"],
        "properties": {
          "id": { "type": "string", "pattern": "^HA-.+" },
          "title": { "type": "string", "minLength": 1 },
          "user_value": { "type": "string", "minLength": 1 },
          "actor": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "obligation_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^HAO-.+" }
          },
          "entrypoint_id": { "type": "string", "minLength": 1 },
          "review_scenario_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "start_state": { "type": "string", "minLength": 1 },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "action", "expected_result", "evidence_requirement", "risk"],
              "properties": {
                "id": { "type": "string", "pattern": "^HA-.+" },
                "action": { "type": "string", "minLength": 1 },
                "expected_result": { "type": "string", "minLength": 1 },
                "evidence_requirement": { "type": "string", "minLength": 1 },
                "risk": { "enum": ["low", "medium", "high"] }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "implementation_deferrals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "deferral_id",
          "deferral_ref",
          "proposal_sha256",
          "confirmation_id",
          "implementation_fingerprint",
          "blocker_refs",
          "affected_task_ids",
          "affected_acceptance_refs",
          "deferred_validation_purposes",
          "exact_excluded_behavior",
          "residual_risk",
          "risk_severity",
          "claims_withheld",
          "reopen_or_stop_condition",
          "downstream_artifact",
          "downstream_owner",
          "defer_until",
          "status",
          "resolution"
        ],
        "properties": {
          "deferral_id": {
            "type": "string",
            "pattern": "^DEF-[0-9a-f]{12}$"
          },
          "deferral_ref": {
            "type": "string",
            "pattern": "^implementation-review/deferrals/DEF-[0-9a-f]{12}\\.json$"
          },
          "proposal_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "confirmation_id": {
            "type": "string",
            "pattern": "^HC-[0-9a-f]{24}$"
          },
          "implementation_fingerprint": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "blocker_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^(T\\d+-B\\d{2}|VALIDATION-(BASELINE|CONVERGENCE))$"
            }
          },
          "affected_task_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^T\\d+$"}
          },
          "affected_acceptance_refs": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "deferred_validation_purposes": {
            "type": "array",
            "uniqueItems": true,
            "items": {"enum": ["baseline", "convergence"]}
          },
          "exact_excluded_behavior": {
            "type": "string",
            "minLength": 1
          },
          "residual_risk": {
            "type": "string",
            "minLength": 1
          },
          "risk_severity": {
            "enum": ["low", "medium"]
          },
          "claims_withheld": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "reopen_or_stop_condition": {
            "type": "string",
            "minLength": 1
          },
          "downstream_artifact": {
            "const": "implementation-handoff.json"
          },
          "downstream_owner": {
            "const": "review"
          },
          "defer_until": {
            "const": "review"
          },
          "status": {
            "enum": ["pending", "resolving", "resolved"]
          },
          "resolution": {
            "oneOf": [
              {"type": "null"},
              {
                "type": "object",
                "required": [
                  "outcome",
                  "summary",
                  "evidence_refs",
                  "evidence_sha256",
                  "review_cycle_id",
                  "implementation_fingerprint"
                ],
                "properties": {
                  "outcome": {"enum": ["passed", "fixed"]},
                  "summary": {"type": "string", "minLength": 1},
                  "evidence_refs": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {"type": "string", "minLength": 1}
                  },
                  "evidence_sha256": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{64}$"
                    }
                  },
                  "review_cycle_id": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$"
                  },
                  "implementation_fingerprint": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$"
                  }
                },
                "additionalProperties": false
              }
            ]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {"const": "resolved"}
              },
              "required": ["status"]
            },
            "then": {
              "properties": {
                "resolution": {"type": "object"}
              }
            }
          },
          {
            "if": {
              "properties": {
                "status": {"enum": ["pending", "resolving"]}
              },
              "required": ["status"]
            },
            "then": {
              "properties": {
                "resolution": {"type": "null"}
              }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "reviewed_runtime_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "mode", "status", "entrypoint_id", "environment_ref", "instance_ref", "configuration_ref", "reviewed_snapshot_sha256", "artifact_ref", "artifact_sha256", "deployment_id", "observed_version", "test_data_refs", "ready_evidence_refs", "review_scenario_ids", "identity_evidence_ref", "identity_evidence_sha256"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "mode": { "enum": ["source", "build", "deployment", "device"] },
          "status": { "const": "ready" },
          "entrypoint_id": { "type": "string", "minLength": 1 },
          "environment_ref": { "type": "string", "minLength": 1 },
          "instance_ref": { "type": "string", "minLength": 1 },
          "configuration_ref": { "type": "string", "minLength": 1 },
          "reviewed_snapshot_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "artifact_ref": { "type": ["string", "null"] },
          "artifact_sha256": { "type": ["string", "null"] },
          "deployment_id": { "type": ["string", "null"] },
          "observed_version": { "type": ["string", "null"] },
          "test_data_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "ready_evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "review_scenario_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "identity_evidence_ref": { "type": "string", "minLength": 1 },
          "identity_evidence_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "review_assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "worker_id", "obligation_ids", "scenario_ids", "read_only", "packet_ref", "result_ref", "packet_sha256", "result_sha256", "review_cycle_id", "observed_snapshot_sha256", "status", "leader_verdict"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["coverage_audit", "scenario_review", "wiring_audit"] },
          "worker_id": { "type": "string", "minLength": 1 },
          "obligation_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "scenario_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "read_only": { "const": true },
          "packet_ref": { "type": "string", "minLength": 1 },
          "result_ref": { "type": "string", "minLength": 1 },
          "packet_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "result_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "review_cycle_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "observed_snapshot_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "status": { "enum": ["dispatched", "returned", "accepted", "rejected"] },
          "leader_verdict": { "enum": ["pending", "accepted", "rejected"] }
        },
        "additionalProperties": true
      }
    },
    "fix_assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "finding_ids", "worker_id", "allowed_write_paths", "changed_paths", "packet_ref", "result_ref", "packet_sha256", "result_sha256", "review_cycle_id", "status", "leader_verdict"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "finding_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "worker_id": { "type": "string", "minLength": 1 },
          "allowed_write_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "changed_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "packet_ref": { "type": "string", "minLength": 1 },
          "result_ref": { "type": "string", "minLength": 1 },
          "packet_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "result_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "review_cycle_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "status": { "enum": ["dispatched", "returned", "accepted", "rejected"] },
          "leader_verdict": { "enum": ["pending", "accepted", "rejected"] }
        },
        "additionalProperties": true
      }
    },
    "revalidations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "worker_id", "finding_ids", "fix_assignment_ids", "fix_assignments_sha256", "scenario_ids", "snapshot_sha256", "result", "evidence_refs", "evidence_sha256", "evidence_manifest_ref", "review_cycle_id", "leader_verdict"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "worker_id": { "type": "string", "minLength": 1 },
          "finding_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "fix_assignment_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "fix_assignments_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "scenario_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "snapshot_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "result": { "enum": ["pass", "fail", "blocked"] },
          "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "evidence_sha256": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" } },
          "evidence_manifest_ref": { "type": "string", "minLength": 1 },
          "review_cycle_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "leader_verdict": { "enum": ["pending", "accepted", "rejected"] }
        },
        "additionalProperties": true
      }
    },
    "coverage": {
      "type": "object",
      "required": ["discovery_complete", "blind_audit_complete", "uncovered_obligation_ids", "uncovered_surface_ids", "final_gap_scan"],
      "properties": {
        "discovery_complete": { "type": "boolean" },
        "blind_audit_complete": { "type": "boolean" },
        "uncovered_obligation_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "uncovered_surface_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "final_gap_scan": { "enum": ["pending", "pass", "fail", "blocked"] }
      },
      "additionalProperties": false
    },
    "leader": {
      "type": "object",
      "required": ["strategy", "review_plan_complete", "all_review_results_joined", "fix_plan_complete", "all_fix_results_joined", "final_revalidation_complete", "verdict"],
      "properties": {
        "strategy": { "enum": ["pending", "leader-plus-subagents"] },
        "review_plan_complete": { "type": "boolean" },
        "all_review_results_joined": { "type": "boolean" },
        "fix_plan_complete": { "type": "boolean" },
        "all_fix_results_joined": { "type": "boolean" },
        "final_revalidation_complete": { "type": "boolean" },
        "verdict": { "enum": ["pending", "pass", "fail", "blocked"] }
      },
      "additionalProperties": false
    },
    "rounds": { "type": "array", "items": { "type": "object" } },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "scenario_id", "classification", "gap_classification", "summary", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "scenario_id": { "type": "string", "minLength": 1 },
          "classification": { "enum": ["startup", "runtime", "wiring", "unreachable", "interaction", "data-flow", "ui", "accessibility", "integration", "regression"] },
          "gap_classification": { "enum": ["implementation_gap", "traceability_gap", "upstream_truth_gap"] },
          "summary": { "type": "string", "minLength": 1 },
          "status": { "enum": ["open", "repairing", "fixed", "verified", "accepted_residual_risk"] }
        },
        "additionalProperties": true
      }
    },
    "repair_cycles": { "type": "array", "items": { "type": "object" } },
    "validation": { "type": "object" },
    "cursor": { "type": "object" },
    "blocker": { "type": ["object", "null"] },
    "final": {
      "type": "object",
      "required": ["verdict", "coverage_verdict", "repair_verdict", "integration_verdict", "all_packets_joined", "reviewed_snapshot_sha256", "implementation_summary_sha256", "runtime_targets_sha256"],
      "properties": {
        "verdict": { "enum": ["pending", "pass", "fail", "blocked"] },
        "coverage_verdict": { "enum": ["pending", "pass", "fail", "blocked"] },
        "repair_verdict": { "enum": ["pending", "pass", "fail", "blocked"] },
        "integration_verdict": { "enum": ["pending", "pass", "fail", "blocked"] },
        "all_packets_joined": { "type": "boolean" },
        "reviewed_snapshot_sha256": { "type": "string" },
        "implementation_summary_sha256": { "type": "string" },
        "runtime_targets_sha256": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
