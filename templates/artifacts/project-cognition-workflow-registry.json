{
  "$schema": "project-cognition-workflow-registry.schema.json",
  "schema_version": 1,
  "workflows": {
    "accept": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Human acceptance records product judgment but does not own repository mutation."
    },
    "analyze": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Analysis is read-only."
    },
    "ask": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Ask is read-only."
    },
    "auto": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "The selected owning workflow performs any required closeout."
    },
    "checklist": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Checklist artifacts are planning-only."
    },
    "clarify": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Clarification changes specification artifacts only."
    },
    "constitution": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Constitution changes are governance artifacts and do not update the code map."
    },
    "debug": {
      "mode": "mutation_closeout",
      "canonical_workflow": "sp-debug",
      "reason": "Debug may repair repository behavior."
    },
    "deep-research": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Research findings and isolated spikes are planning inputs."
    },
    "design": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Design writes design artifacts, not implementation."
    },
    "discussion": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Discussion writes planning state only."
    },
    "explain": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Explain is read-only."
    },
    "fast": {
      "mode": "mutation_closeout",
      "canonical_workflow": "sp-fast",
      "reason": "Fast performs a bounded repository change."
    },
    "implement": {
      "mode": "mutation_closeout",
      "canonical_workflow": "sp-implement",
      "reason": "Implement owns repository changes."
