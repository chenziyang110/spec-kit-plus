    },
    "map-scan": {
      "mode": "baseline_maintenance",
      "canonical_workflow": null,
      "reason": "Map Scan produces baseline evidence through its dedicated acceptance contract."
    },
    "map-update": {
      "mode": "map_maintenance",
      "canonical_workflow": "sp-map-update",
      "reason": "Map Update is the explicit incremental maintenance entrypoint."
    },
    "plan": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Plan artifacts are planning-only."
    },
    "prd": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "PRD artifacts are planning-only."
    },
    "prd-build": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "PRD reconstruction writes planning artifacts only."
    },
    "prd-scan": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "PRD scanning records planning evidence only."
    },
    "quick": {
      "mode": "mutation_closeout",
      "canonical_workflow": "sp-quick",
      "reason": "Quick performs a tracked repository change."
    },
    "research": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Research routes to planning research artifacts."
    },
    "review": {
      "mode": "mutation_closeout",
      "canonical_workflow": "sp-review",
      "reason": "Review may repair integrated repository behavior."
    },
    "specify": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Specification artifacts are planning-only."
    },
    "tasks": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Task artifacts are planning-only."
    },
    "taskstoissues": {
      "mode": "no_closeout",
      "canonical_workflow": null,
      "reason": "Issue export does not own repository source mutation."
