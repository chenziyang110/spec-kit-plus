{
  "name": "spec-kit-plus-agent-teams-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Bundled multi-agent execution engine for the spec-kit-plus agent-teams extension",
  "type": "module",
  "main": "src/cli/bridge.js",
  "scripts": {
    "build": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true});\" && tsc",
    "start:runtime": "node dist/team/runtime-cli.js",
    "test:bridge": "node --test tests/bridge.test.mjs",
    "test:native-hooks": "npm run build && node --test dist/scripts/__tests__/codex-native-hook.test.js dist/hooks/__tests__/specify-quality-adapter.test.js dist/config/__tests__/codex-hooks.test.js dist/cli/__tests__/native-hook-dispatch-contract.test.js dist/cli/__tests__/setup-hooks-shared-ownership.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "js-yaml": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "ajv": ">=8.18.0",
    "hono": ">=4.11.10"
  }
}
