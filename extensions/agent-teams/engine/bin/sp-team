#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENTRY="$SCRIPT_DIR/../dist/cli/omx.js"

if [ ! -f "$ENTRY" ]; then
  echo "sp-team: missing runtime entrypoint at $ENTRY" >&2
  exit 1
fi

case "${1:-}" in
  status|await|resume|shutdown)
    cmd="$1"
    shift
    exec node "$ENTRY" team "$cmd" "$@"
    ;;
  "")
    exec node "$ENTRY" team api --help
    ;;
  *)
    exec node "$ENTRY" team api "$@"
    ;;
esac
